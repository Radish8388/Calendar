<Window x:Class="Calendar.SelectYear"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Calendar"
        mc:Ignorable="d"
        Title="Select Year"
        Height="220" Width="250"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <StackPanel Margin="20">
        <TextBlock Text="Enter a year (1582 or later):"/>
        <TextBox Name="YearText" Margin="0,10,0,0"/>
        <Button Content="OK" Width="75" Margin="0,20,0,0" Click="OK_Click" IsDefault="True"/>
        <Button Content="Cancel" Width="75" Margin="0,20,0,0" Click="Cancel_Click" IsCancel="True"/>
    </StackPanel>
</Window>
