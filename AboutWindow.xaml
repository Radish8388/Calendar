<Window x:Class="Calendar.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Calendar"
        mc:Ignorable="d"
        Title="About Calendar"
        Height="300" Width="200"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <Image Source="/calendar.png"  Width="32" Height="32" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBlock Text="Calendar" FontSize="18" FontWeight="Bold"/>
        <TextBlock Text="Version 1.1" Margin="0,10,0,0"/>
        <TextBlock Text="Created by Radish" Margin="0,5,0,0"/>

        <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,5,0,5">
        <Hyperlink NavigateUri="https://radish-vert.vercel.app" RequestNavigate="Hyperlink_RequestNavigate">
            radish-vert.vercel.app
        </Hyperlink>
        </TextBlock>

        <TextBlock Text="© 2026" Margin="0,5,0,0"/>
        <Button Content="OK" Width="75" Margin="0,20,0,0" Click="OK_Click" IsDefault="True"/>
    </StackPanel>
</Window>
